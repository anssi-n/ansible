---
# https://kubernetes.io/docs/setup/production-environment/tools/kubeadm/setup-ha-etcd-with-kubeadm/

# 1. Configure the kubelet to be a service manager for etcd. Do this in all the etcd cluster nodes.

- name: Ensure /etc/systemd/system/kubelet.service.d directory exists
  ansible.builtin.file:
    path: /etc/systemd/system/kubelet.service.d
    state: directory

- name: Copy KubeletConfiguration and service manager configuration files to etcd host
  ansible.builtin.copy:
    src: "{{ item }}"
    dest: "/etc/systemd/system/kubelet.service.d/{{ item }}"
  loop:
    - kubelet.conf
    - 20-etcd-service-manager.conf
  notify: restart kubelet

- name: Run pending handlers
  meta: flush_handlers

- name: Ensure kubelet is running
  ansible.builtin.service:
    name: kubelet
    state: started
    enabled: yes

# 2. Create configuration files for kubeadm. Do this only on the first node.

- ansible.builtin.set_fact:
    etcd_names: "{{ groups['etcd_nodes'] }}"
    etcd_hosts: "{{ groups['etcd_nodes'] | map('extract', hostvars, 'ansible_host') | list }}"
    etcd_non_primary_hosts: "{{ groups['etcd_nodes'] | map('extract', hostvars, 'ansible_host') | list | reject('search', ansible_host)}}"
  run_once: true

- name: Ensure temporary directories for each etcd cluster node configuration exits
  ansible.builtin.file:
    path: "/tmp/{{ item }}"
    state: directory
  loop: "{{ etcd_hosts }}"
  run_once: true

- name: Create kubeadm configuration files for each etcd cluster node
  ansible.builtin.template:
    src: kubeadm_config.j2
    dest: "/tmp/{{ item }}/kubeadmcfg.yaml"
  loop: "{{ etcd_hosts }}"
  loop_control:
    index_var: idx
  run_once: true

# 3. Generate the certificate authority. Do this only on the first node.

- name: Generate the certificate authority
  ansible.builtin.command:
    cmd: kubeadm init phase certs etcd-ca
    creates: /etc/kubernetes/pki/etcd/ca.crt
  run_once: true

# 4. Create certificates for each member. Do this only on the first node.

- name: Create certificates for other nodes
  ansible.builtin.include_tasks: create_host_certificates.yaml
  loop: "{{ etcd_non_primary_hosts }}"
  loop_control:
    loop_var: current_host
  run_once: true

- name: Create certificates for primary nodes
  ansible.builtin.command:
    cmd: "{{ item }}"
    creates: "/tmp/{{ ansible_host }}/pki/etcd/server.crt"
  loop:
    - "kubeadm init phase certs etcd-server --config=/tmp/{{ ansible_host }}/kubeadmcfg.yaml"
    - "kubeadm init phase certs etcd-peer --config=/tmp/{{ ansible_host }}/kubeadmcfg.yaml"
    - "kubeadm init phase certs etcd-healthcheck-client --config=/tmp/{{ ansible_host }}/kubeadmcfg.yaml"
    - "kubeadm init phase certs apiserver-etcd-client --config=/tmp/{{ ansible_host }}/kubeadmcfg.yaml"
    - "cp -R /etc/kubernetes/pki /tmp/{{ ansible_host }}/"
  run_once: true

- name: Clean up certs that should not be copied off this host
  ansible.builtin.command:
    cmd: "find /tmp/{{ item }} -name ca.key -type f -delete"
    removes: "/tmp/{{ item }}/pki/etcd/ca.key"
  loop: "{{ etcd_non_primary_hosts }}"
  run_once: true

# 5. Copy certificates and kubeadm configs. Do this only on the first node.

- name: Create temporary directories on localhost for each non-primary etcd node
  ansible.builtin.file:
    path: "/tmp/{{ item }}"
    state: directory
  loop: "{{ etcd_non_primary_hosts }}"
  delegate_to: localhost
  run_once: true



- name: Copy certs and kubeadm configs

  ansible.builtin.fetch:
    src: "/tmp/{{ "
    dest: /tmp/
    flat: true
  loop: "{{ etcd_non_primary_hosts }}"
  run_once: true

# Copy all to target host /tmp/{{ ansible_host }}/ dir

#USER=ubuntu
#HOST=${HOST1}
#scp -r /tmp/${HOST}/* ${USER}@${HOST}:
#ssh ${USER}@${HOST}
#USER@HOST $ sudo -Es
#root@HOST $ chown -R root:root pki
#root@HOST $ mv pki /etc/kubernetes/

# /etc/kubernetes/pki does not exists on etcd-2 & etcd-3

# 6. Ensure all expected files exist.
# 7. Create the static pod manifests.
# 8. Optional: Check the cluster health.

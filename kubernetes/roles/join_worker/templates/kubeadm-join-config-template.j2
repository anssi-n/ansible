---
apiVersion: kubeadm.k8s.io/v1beta4
kind: JoinConfiguration

discovery:
  bootstrapToken:
    token: "{{ join_token }}"
    apiServerEndpoint: "{{ api_server_endpoint }}"
    caCertHashes:
      - "{{ ca_cert_hash }}"

nodeRegistration:
  kubeletExtraArgs:
    - name: node-ip
      value: {{ ansible_host }}

networking:
  podSubnet: "{{ pod_network_cidr }}"
  serviceSubnet: "{{ service_network_cidr }}"

apiServer:
  certSANs: {{ apiserver_cert_extra_sans | safe | replace('\'', '\"') }}
  extraArgs:
    - name: bind-address
      value: "0.0.0.0"

controllerManager:
  extraArgs:
    - name: bind-address
      value: "0.0.0.0"

scheduler:
  extraArgs:
    - name: bind-address
      value: "0.0.0.0"


---
apiVersion: kubeadm.k8s.io/v1beta4
kind: JoinConfiguration

discovery:
  bootstrapToken:
    token: "{{ join_control_join_token }}"
    apiServerEndpoint: "{{ join_control_api_server_endpoint }}"
    caCertHashes:
      - "{{ join_control_ca_cert_hash }}"

{% if join_control_cert_key is defined %}
controlPlane:
  localAPIEndpoint:
    advertiseAddress: {{ ansible_host }}
    bindPort: 6443
  certificateKey: "{{ join_control_cert_key }}"
{% endif %}

nodeRegistration:
  kubeletExtraArgs:
    - name: node-ip
      value: {{ ansible_host }}

networking:
  podSubnet: "{{ init_cluster_pod_network_cidr }}"
  serviceSubnet: "{{ init_cluster_service_network_cidr }}"

apiServer:
  certSANs: {{ init_cluster_apiserver_cert_extra_sans | safe | replace('\'', '\"') }}
  extraArgs:
    - name: bind-address
      value: "0.0.0.0"

controllerManager:
  extraArgs:
    - name: bind-address
      value: "0.0.0.0"

scheduler:
  extraArgs:
    - name: bind-address
      value: "0.0.0.0"

{% if not join_control_external_etcd %}
etcd:
  local:
    serverCertSANs:
      - "{{ ansible_host }}"
    peerCertSANs:
      - "{{ ansible_host }}"
    extraArgs:
      - name: listen-client-urls
        value: "https://0.0.0.0:2379"
      - name: listen-peer-urls
        value: "https://0.0.0.0:2380"
      - name: advertise-client-urls
        value: "https://{{ ansible_host }}:2379"
      - name: initial-advertise-peer-urls
        value: "https://{{ ansible_host }}:2380"
{% else %}
etcd:
  external:
    endpoints: [{%- for host in groups['etcd_nodes'] -%}
                         "https://{{ hostvars[host].ansible_host }}:2379"{% if not loop.last %},{% endif %}
                       {%- endfor -%}]{{ ''}}
    caFile: /etc/kubernetes/pki/etcd/ca.crt
    certFile: /etc/kubernetes/pki/apiserver-etcd-client.crt
    keyFile: /etc/kubernetes/pki/apiserver-etcd-client.key
{% endif %}
